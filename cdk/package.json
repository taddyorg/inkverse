{
  "name": "inkverse-cdk",
  "version": "0.1.0",
  "private": true,
  "description": "AWS CDK infrastructure for Inkverse (migrated off AWS Copilot)",
  "bin": {
    "inkverse": "bin/inkverse.ts"
  },
  "scripts": {
    "build": "tsc",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "task": "ts-node scripts/run-task.ts",
    "migrate": "ts-node scripts/run-migrate.ts",
    "gc": "cdk gc --unstable=gc --type=ecr --action=print"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "aws-cdk": "^2.1128.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.700.0",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2"
  }
}
